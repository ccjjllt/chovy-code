# Provider keys — copy to `.env` and fill in the ones you use.
# chovy-code reads these at runtime; only the provider you select needs a key.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
MINIMAX_API_KEY=
GLM_API_KEY=
KIMI_API_KEY=

# Override the default provider/model if desired.
CHOVY_PROVIDER=
CHOVY_MODEL=
