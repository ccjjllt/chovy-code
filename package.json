{
  "name": "chovy-code",
  "version": "0.1.0",
  "description": "A coding agent built with Bun + TypeScript + React/Ink.",
  "type": "module",
  "bin": {
    "chovy": "./bin/chovy.js"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun --watch src/cli/index.tsx",
    "build": "bun run scripts/build.ts",
    "start": "bun run src/cli/index.tsx",
    "typecheck": "tsc --noEmit",
    "demo": "bun run scripts/demo.ts",
    "smoke": "bun run scripts/smoke.ts",
    "bench": "bun run bench:tool-budget && bun run bench:memory-fts && bun run bench:swarm-100 && bun run bench:context-rebuild",
    "bench:tool-budget": "bun run scripts/bench/tool-budget.bench.ts",
    "bench:memory-fts": "bun run scripts/bench/memory-fts.bench.ts",
    "bench:swarm-100": "bun run scripts/bench/swarm-100.bench.ts",
    "bench:context-rebuild": "bun run scripts/bench/context-rebuild.bench.ts",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "coding-agent",
    "cli",
    "ai",
    "llm",
    "bun",
    "ink"
  ],
  "license": "MIT",
  "engines": {
    "bun": ">=1.1.0"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "ink": "^5.0.1",
    "react": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^18.3.3",
    "typescript": "^5.5.4"
  }
}
